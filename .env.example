# Copy this file to .env and fill in your values.
# .env is git-ignored and will never be committed.

# Your LiveKit Cloud login email
LIVEKIT_EMAIL=your.email@example.com

# Project ID — visible in the LiveKit Cloud URL:
# https://cloud.livekit.io/projects/<PROJECT_ID>/sessions
LIVEKIT_PROJECT_ID=p_xxxxxxxxxxxxxxx
